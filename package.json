{
  "name": "btms",
  "version": "1.0.0",
  "description": "Bus Terminal Management System – monorepo root",
  "private": true,
  "scripts": {
    "frontend": "npm run dev --prefix bus-terminal-management-system",
    "backend": "npm run dev --prefix backend",
    "dev": "concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm run backend\" \"npm run frontend\"",
    "build": "npm run build --prefix bus-terminal-management-system",
    "seed": "npm run seed --prefix backend",
    "seed:destroy": "npm run seed:destroy --prefix backend",
    "db:clean": "npm run db:clean --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
